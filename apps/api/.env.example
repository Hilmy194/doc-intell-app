# Supabase
SUPABASE_URL=https://your-project.supabase.co
# Service Role Key is required for the backend — it bypasses RLS so the API
# can read/write storage and the database without permission errors.
# Find it in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_BUCKET=documents

# Server
PORT=4000
PYTHON_PATH=python

# Frontend origin (for CORS) — set to your deployed frontend URL in production
WEB_URL=http://localhost:5173

# JWT secret — CHANGE THIS in production!
JWT_SECRET=docintel-jwt-secret-change-in-production
