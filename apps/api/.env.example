# Supabase
SUPABASE_URL=https://your-project.supabase.co
# Service Role Key is required for the backend — it bypasses RLS so the API
# can read/write storage and the database without permission errors.
# Find it in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_BUCKET=documents

# Server
PORT=4000
PYTHON_PATH=python

# Frontend origin (for CORS) — set to your deployed frontend URL in production
WEB_URL=http://localhost:5173

# JWT secret — CHANGE THIS in production!
JWT_SECRET=docintel-jwt-secret-change-in-production

# Neo4j (optional — only needed for advanced graph queries; all features work without it)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-neo4j-password

# OpenAI — set this to enable AI-powered entity extraction (recommended)
# When set, auto-detects to openai mode. Without it, falls back to regex heuristic.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# ENTITY_EXTRACTOR=openai   # auto-detected when OPENAI_API_KEY is set; override: heuristic | openai | hybrid
